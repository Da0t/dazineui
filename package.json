{
  "name": "dazineui",
  "version": "0.1.0",
  "description": "Motion primitives for AI-built UI. Install once — every AI session produces senior-level Three.js designs.",
  "keywords": [
    "threejs",
    "react",
    "motion",
    "animation",
    "primitives",
    "ai",
    "design",
    "webgl",
    "glsl",
    "react-three-fiber",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/primitives/flow-gradient/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/primitives/flow-gradient/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "primitives",
    "lib/hooks",
    "bin",
    "scripts",
    "MANIFEST.md",
    "SKILL.md",
    ".cursor/rules"
  ],
  "bin": {
    "dazineui": "./bin/setup"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:lib": "tsup && tsc --project tsconfig.build.json",
    "postinstall": "node scripts/postinstall.js || true"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160.0",
    "@react-three/fiber": ">=8",
    "@react-three/drei": ">=9",
    "@react-three/postprocessing": ">=2"
  },
  "peerDependenciesMeta": {
    "@react-three/postprocessing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "geist": "^1.7.1",
    "lenis": "^1.3.23",
    "motion": "^12.39.0",
    "next": "^15.5.18",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
